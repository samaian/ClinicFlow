@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var isDashboard = currentController == "PatientUI" && currentAction == "Dashboard";
    var isProfile = currentController == "PatientUI" && currentAction == "Profile";

    var firstLetter = !string.IsNullOrWhiteSpace(User.Identity?.Name)
        ? User.Identity.Name[0].ToString().ToUpper()
        : "U";
}

<!DOCTYPE html>
<html lang="en" data-theme="winter">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>@ViewData["Title"] - ClinicFlow</title>

    <link href="https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        html {
        scroll-behavior: smooth;
        }

        body {
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
        }

        #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: linear-gradient(90deg, #2563eb, #38bdf8);
        z-index: 9999;
        }

        .page-bg {
        background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.08), transparent 25%), radial-gradient(circle at top right, rgba(14, 165, 233, 0.08), transparent 25%), radial-gradient(circle at bottom center, rgba(96, 165, 250, 0.06), transparent 30%);
        }

        .glass-nav {
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        }

        [data-theme="night"] .glass-nav,
        [data-theme="dracula"] .glass-nav,
        [data-theme="dark"] .glass-nav {
        background: rgba(17, 24, 39, 0.72);
        }

        .sidebar-full {
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        width: 270px;
        z-index: 40;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-right: 1px solid rgba(255, 255, 255, 0.2);
        overflow-y: auto;
        padding: 1.5rem 1rem 1rem 1rem;
        display: flex;
        flex-direction: column;
        }

        [data-theme="night"] .sidebar-full,
        [data-theme="dracula"] .sidebar-full {
        background: rgba(17, 24, 39, 0.55);
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        }

        .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        padding: 0.5rem 0.5rem 1rem 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 1.5rem;
        }

        .sidebar-logo .logo-icon {
        width: 40px;
        height: 40px;
        border-radius: 0.75rem;
        background: linear-gradient(135deg, #2563eb, #38bdf8);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.25rem;
        flex-shrink: 0;
        }

        .sidebar-logo .logo-text {
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--fallback-p, oklch(var(--p)));
        }

        .portal-title {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0.4;
        margin-bottom: 0.75rem;
        padding: 0 0.5rem;
        }

        .sidebar-link {
        transition: all 0.2s ease;
        border-radius: 0.75rem;
        padding: 0.6rem 1rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--fallback-bc, oklch(var(--bc)/0.7));
        font-size: 0.9rem;
        }

        .sidebar-link:hover {
        background: var(--fallback-p, oklch(var(--p)/0.08));
        color: var(--fallback-p, oklch(var(--p)));
        }

        .sidebar-link.active {
        background: var(--fallback-p, oklch(var(--p)));
        color: var(--fallback-pc, oklch(var(--pc)));
        box-shadow: 0 4px 16px -4px var(--fallback-p, oklch(var(--p)/0.3));
        font-weight: 600;
        }

        .user-section {
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        }

        .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 9999px;
        background: var(--fallback-p, oklch(var(--p)));
        color: var(--fallback-pc, oklch(var(--pc)));
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
        }

        .user-actions a {
        font-size: 0.85rem;
        padding: 0.4rem 0.5rem;
        border-radius: 0.5rem;
        transition: all 0.2s ease;
        color: var(--fallback-bc, oklch(var(--bc)/0.6));
        display: block;
        }

        .user-actions a:hover {
        background: var(--fallback-p, oklch(var(--p)/0.08));
        color: var(--fallback-p, oklch(var(--p)));
        }

        .user-actions .sign-out {
        color: var(--fallback-er, oklch(var(--er)));
        }

        .user-actions .sign-out:hover {
        background: var(--fallback-er, oklch(var(--er)/0.1));
        color: var(--fallback-er, oklch(var(--er)));
        }

        /* ====== MAIN WRAPPER ====== */
        .main-wrapper {
        margin-left: 270px;
        padding-top: 76px;
        min-height: 100vh;
        padding-left: 1rem;
        padding-right: 1rem;
        padding-bottom: 1rem;
        }

        .content-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        padding: 1.25rem;
        min-height: calc(100vh - 110px);
        }

        [data-theme="night"] .content-card,
        [data-theme="dracula"] .content-card {
        background: rgba(17, 24, 39, 0.45);
        border: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* ====== Mobile ====== */
        @@media (max-width: 1024px) {
        .sidebar-full {
        transform: translateX(-100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 50;
        width: 280px;
        }

        .sidebar-full.open {
        transform: translateX(0);
        }

        .main-wrapper {
        margin-left: 0;
        padding-top: 68px;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
        }

        .content-card {
        min-height: calc(100vh - 100px);
        padding: 1rem;
        }

        .sidebar-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        z-index: 45;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
        }

        .sidebar-overlay.open {
        opacity: 1;
        pointer-events: all;
        }
        }

        @@media (min-width: 1025px) {
        .sidebar-overlay {
        display: none;
        }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="min-h-screen bg-base-100 text-base-content flex flex-col page-bg">

    <div id="scroll-progress"></div>
    <div id="sidebarOverlay" class="sidebar-overlay"></div>

    <!-- ===== SIDEBAR ===== -->
    <aside id="sidebarFull" class="sidebar-full">
        <!-- Logo -->
        <a asp-controller="Home" asp-action="Index" class="sidebar-logo">
            <div class="logo-icon">C</div>
            <span class="logo-text">ClinicFlow</span>
        </a>

        <!-- Patient Portal -->
        <div class="portal-title">Patient Portal</div>

        <!-- ===== الروابط فقط Dashboard & Profile ===== -->
        <nav class="flex-1 space-y-1">
            <a asp-controller="PatientUI" asp-action="Dashboard"
                   class="sidebar-link @(isDashboard ? "active" : "")">
                <span>📊</span> Dashboard
            </a>
            <a asp-controller="PatientUI" asp-action="Profile"
                   class="sidebar-link @(isProfile ? "active" : "")">
                <span>👤</span> Profile
            </a>
        </nav>

        <!-- User Section -->
        <div class="user-section">
            <div class="flex items-center gap-3">
                <div class="user-avatar">@firstLetter</div>
                <div>
                    <div class="font-semibold text-sm">@(User.Identity?.Name ?? "Guest")</div>
                    <div class="text-xs opacity-50">Account Verified</div>
                </div>
            </div>
            <div class="user-actions mt-2">
                <a asp-controller="Home" asp-action="Index">🏠 Return to Website</a>
                <a asp-controller="Account" asp-action="Logout" class="sign-out">🚪 Sign Out</a>
            </div>
        </div>
    </aside>

    <!-- ===== NAVBAR ===== -->
    <header id="mainNavbar" class="fixed top-0 left-0 right-0 z-30 transition-all duration-500 translate-y-0">
        <div class="navbar glass-nav border-b border-base-200/60 px-4 md:px-8 shadow-sm">
            <div class="navbar-start">
                <button id="sidebarMobileToggle" class="btn btn-ghost btn-sm rounded-xl lg:hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                <span class="text-xl font-black text-primary lg:hidden ml-2">@ViewData["Title"]</span>
            </div>
            <div class="navbar-center hidden lg:flex">
                <ul class="menu menu-horizontal gap-1 px-1 font-medium">
                    <li><a class="rounded-xl hover:text-primary hover:bg-primary/10 transition" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="rounded-xl hover:text-primary hover:bg-primary/10 transition" asp-controller="DoctorsUI" asp-action="Index">Doctors</a></li>
                    <li><a class="rounded-xl hover:text-primary hover:bg-primary/10 transition" asp-controller="SpecialtiesUI" asp-action="Index">Specialties</a></li>
                    <li><a class="rounded-xl hover:text-primary hover:bg-primary/10 transition" asp-controller="Home" asp-action="About">About</a></li>
                    <li><a class="rounded-xl hover:text-primary hover:bg-primary/10 transition" asp-controller="Home" asp-action="Contact">Contact</a></li>
                </ul>
            </div>
            <div class="navbar-end gap-2">
                <!-- Theme -->
                <div class="dropdown dropdown-end">
                    <div tabindex="0" role="button" class="btn btn-ghost btn-sm rounded-xl gap-2 hover:bg-base-200 transition">
                        🎨 <span class="text-sm font-semibold hidden sm:inline">Theme</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                    <ul tabindex="0" class="dropdown-content menu p-3 shadow-2xl bg-base-100/90 backdrop-blur-xl rounded-2xl w-52 mt-3 border border-base-200 z-[100]">
                        <li><button onclick="setTheme('winter')" class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200 transition"><span class="w-3 h-3 rounded-full bg-sky-400"></span> Winter</button></li>
                        <li><button onclick="setTheme('light')" class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200 transition"><span class="w-3 h-3 rounded-full bg-yellow-300"></span> Light</button></li>
                        <li><button onclick="setTheme('night')" class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200 transition"><span class="w-3 h-3 rounded-full bg-indigo-500"></span> Night</button></li>
                        <li><button onclick="setTheme('dracula')" class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200 transition"><span class="w-3 h-3 rounded-full bg-purple-500"></span> Dracula</button></li>
                    </ul>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown dropdown-end">
                        <label tabindex="0" class="flex items-center gap-3 px-3 py-2 rounded-full bg-base-200 hover:bg-base-300 transition cursor-pointer">
                            <div class="w-8 h-8 rounded-full bg-primary text-primary-content flex items-center justify-center font-bold">@firstLetter</div>
                            <span class="text-sm font-semibold hidden sm:inline">@(User.Identity?.Name?.Split(" ")[0] ?? "Account")</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </label>
                        <ul tabindex="0" class="dropdown-content menu p-3 shadow-xl bg-base-100/90 backdrop-blur-xl rounded-2xl w-52 mt-3 border border-base-200">
                            <li><a asp-controller="PatientUI" asp-action="Dashboard">📊 Dashboard</a></li>
                            <li><a asp-controller="PatientUI" asp-action="Profile">👤 Profile</a></li>
                            <li class="border-t mt-2 pt-2"><a asp-controller="Account" asp-action="Logout" class="text-error font-semibold hover:bg-base-200 rounded-xl">🚪 Logout</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-ghost btn-sm rounded-full px-4 hover:bg-base-200 transition">Log In</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm rounded-full px-4 shadow-md shadow-primary/20 hover:scale-[1.02] transition">Sign Up</a>
                }
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-wrapper">
        <div class="content-card shadow-xl">
            @RenderBody()
        </div>
    </div>

    <script>
        function setTheme(theme) {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
        }

        document.addEventListener("DOMContentLoaded", function() {
        const saved = localStorage.getItem("theme");
        if (saved) document.documentElement.setAttribute("data-theme", saved);

        const navbar = document.getElementById("mainNavbar");
        const progress = document.getElementById("scroll-progress");
        let lastScrollY = window.scrollY;

        window.addEventListener("scroll", () => {
        const currentScrollY = window.scrollY;
        const winScroll = document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        progress.style.width = scrolled + "%";
        if (currentScrollY > 10) navbar.classList.add("shadow-lg");
        else navbar.classList.remove("shadow-lg");
        if (currentScrollY > lastScrollY && currentScrollY > 90) {
        navbar.classList.remove("translate-y-0");
        navbar.classList.add("-translate-y-full");
        } else {
        navbar.classList.remove("-translate-y-full");
        navbar.classList.add("translate-y-0");
        }
        lastScrollY = currentScrollY;
        });

        const sidebar = document.getElementById("sidebarFull");
        const overlay = document.getElementById("sidebarOverlay");
        const openBtn = document.getElementById("sidebarMobileToggle");

        function openSidebar() {
        sidebar.classList.add("open");
        overlay.classList.add("open");
        document.body.style.overflow = "hidden";
        }
        function closeSidebar() {
        sidebar.classList.remove("open");
        overlay.classList.remove("open");
        document.body.style.overflow = "";
        }

        if (openBtn) openBtn.addEventListener("click", openSidebar);
        if (overlay) overlay.addEventListener("click", closeSidebar);

        document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && sidebar.classList.contains("open")) closeSidebar();
        });

        window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024) closeSidebar();
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_NotificationPartial")
</body>
</html>