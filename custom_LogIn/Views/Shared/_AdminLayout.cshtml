@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isDashboard   = currentAction == "Dashboard";
    var isProfile     = currentAction == "Profile";
    var firstLetter   = !string.IsNullOrWhiteSpace(User.Identity?.Name)
        ? User.Identity.Name[0].ToString().ToUpper()
        : "A";
}

<!DOCTYPE html>
<html lang="en" data-theme="winter">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - ClinicFlow Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; }

        #scroll-progress {
            position: fixed; top: 0; left: 0; height: 3px; width: 0%;
            background: linear-gradient(90deg, #7c3aed, #a78bfa); z-index: 9999;
        }

        .page-bg {
            background: radial-gradient(circle at top left, rgba(124,58,237,.07), transparent 25%),
                        radial-gradient(circle at top right, rgba(167,139,250,.07), transparent 25%),
                        radial-gradient(circle at bottom center, rgba(139,92,246,.05), transparent 30%);
        }

        .glass-nav {
            background: rgba(255,255,255,.72);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
        }
        [data-theme="night"] .glass-nav,
        [data-theme="dracula"] .glass-nav { background: rgba(17,24,39,.72); }

        /* ── Sidebar ── */
        .sidebar-full {
            position: fixed; top: 0; left: 0; height: 100vh; width: 260px; z-index: 40;
            background: rgba(255,255,255,.55); backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-right: 1px solid rgba(255,255,255,.2);
            overflow-y: auto; padding: 1.5rem 1rem 1rem; display: flex; flex-direction: column;
        }
        [data-theme="night"] .sidebar-full,
        [data-theme="dracula"] .sidebar-full {
            background: rgba(17,24,39,.55);
            border-right: 1px solid rgba(255,255,255,.08);
        }

        .sidebar-logo { display:flex; align-items:center; gap:.75rem; text-decoration:none;
            padding:.5rem .5rem 1rem; border-bottom:1px solid rgba(255,255,255,.08); margin-bottom:1.5rem; }
        .sidebar-logo .logo-icon {
            width:40px; height:40px; border-radius:.75rem;
            background:linear-gradient(135deg,#7c3aed,#a78bfa);
            color:#fff; display:flex; align-items:center; justify-content:center;
            font-weight:900; font-size:1.25rem; flex-shrink:0;
        }
        .sidebar-logo .logo-text { font-size:1.25rem; font-weight:900; color:oklch(var(--p)); }

        .portal-title {
            font-size:.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
            opacity:.4; margin-bottom:.75rem; padding:0 .5rem;
        }

        .sidebar-link {
            transition:all .2s ease; border-radius:.75rem; padding:.6rem 1rem;
            font-weight:500; display:flex; align-items:center; gap:.75rem;
            color:oklch(var(--bc)/.7); font-size:.9rem;
        }
        .sidebar-link:hover  { background:oklch(var(--p)/.08); color:oklch(var(--p)); }
        .sidebar-link.active {
            background:oklch(var(--p)); color:oklch(var(--pc));
            box-shadow:0 4px 16px -4px oklch(var(--p)/.3); font-weight:600;
        }

        .sidebar-section-label {
            font-size:.65rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
            opacity:.35; padding:1rem .5rem .4rem; display:block;
        }

        .user-section { margin-top:auto; padding-top:1rem; border-top:1px solid rgba(255,255,255,.1); }
        .user-avatar {
            width:40px; height:40px; border-radius:9999px;
            background:oklch(var(--p)); color:oklch(var(--pc));
            display:flex; align-items:center; justify-content:center;
            font-weight:700; font-size:1rem; flex-shrink:0;
        }
        .user-actions a {
            font-size:.85rem; padding:.4rem .5rem; border-radius:.5rem;
            transition:all .2s ease; color:oklch(var(--bc)/.6); display:block;
        }
        .user-actions a:hover { background:oklch(var(--p)/.08); color:oklch(var(--p)); }
        .user-actions .sign-out { color:oklch(var(--er)); }
        .user-actions .sign-out:hover { background:oklch(var(--er)/.1); color:oklch(var(--er)); }

        /* ── Main ── */
        .main-wrapper { margin-left:260px; padding-top:76px; min-height:100vh; padding:76px 1rem 1rem; }
        .content-card {
            background:rgba(255,255,255,.45); backdrop-filter:blur(12px);
            -webkit-backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,.15);
            border-radius:1.5rem; padding:1.5rem; min-height:calc(100vh - 110px);
        }
        [data-theme="night"] .content-card,
        [data-theme="dracula"] .content-card {
            background:rgba(17,24,39,.45); border:1px solid rgba(255,255,255,.08);
        }

        /* Mobile */
        @@media (max-width:1024px) {
            .sidebar-full { transform:translateX(-100%); transition:transform .3s cubic-bezier(.4,0,.2,1); z-index:50; width:280px; }
            .sidebar-full.open { transform:translateX(0); }
            .main-wrapper { margin-left:0; padding-top:68px; padding-left:.5rem; padding-right:.5rem; }
            .content-card { min-height:calc(100vh - 100px); padding:1rem; }
            .sidebar-overlay { position:fixed; inset:0; background:rgba(0,0,0,.4);
                backdrop-filter:blur(4px); z-index:45; opacity:0; pointer-events:none; transition:opacity .3s ease; }
            .sidebar-overlay.open { opacity:1; pointer-events:all; }
        }
        @@media (min-width:1025px) { .sidebar-overlay { display:none; } }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="min-h-screen bg-base-100 text-base-content flex flex-col page-bg">

    <div id="scroll-progress"></div>
    <div id="sidebarOverlay" class="sidebar-overlay"></div>

    <!-- ── SIDEBAR ── -->
    <aside id="sidebarFull" class="sidebar-full">
        <a asp-controller="Home" asp-action="Index" class="sidebar-logo">
            <div class="logo-icon">C</div>
            <div>
                <span class="logo-text">ClinicFlow</span>
                <span class="block text-[10px] opacity-40 font-semibold tracking-widest uppercase -mt-0.5">Admin Panel</span>
            </div>
        </a>

        <div class="portal-title">Overview</div>
        <nav class="flex-1 space-y-1">
            <a asp-controller="AdminUI" asp-action="Dashboard"
               class="sidebar-link @(isDashboard ? "active" : "")">
                <span>📊</span> Dashboard
            </a>

            <span class="sidebar-section-label">Account</span>
            <a asp-controller="AdminUI" asp-action="Profile"
               class="sidebar-link @(isProfile ? "active" : "")">
                <span>👤</span> My Profile
            </a>
        </nav>

        <div class="user-section">
            <div class="flex items-center gap-3">
                <div class="user-avatar">@firstLetter</div>
                <div>
                    <div class="font-semibold text-sm">@(User.Identity?.Name ?? "Admin")</div>
                    <div class="text-xs opacity-50 uppercase tracking-wider">Administrator</div>
                </div>
            </div>
            <div class="user-actions mt-2">
                <a asp-controller="Home" asp-action="Index">🏠 Public Site</a>
                <a asp-controller="Account" asp-action="Logout" class="sign-out">🚪 Sign Out</a>
            </div>
        </div>
    </aside>

    <!-- ── TOPBAR ── -->
    <header id="mainNavbar" class="fixed top-0 left-0 right-0 z-30 transition-all duration-500">
        <div class="navbar glass-nav border-b border-base-200/60 px-4 shadow-sm">
            <div class="navbar-start">
                <button id="sidebarMobileToggle" class="btn btn-ghost btn-sm rounded-xl lg:hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                <span class="text-lg font-black text-primary lg:hidden ml-2">@ViewData["Title"]</span>
            </div>
            <div class="navbar-center hidden lg:block">
                <span class="font-bold text-base-content/60 text-sm tracking-wide uppercase">
                    Admin Panel — @ViewData["Title"]
                </span>
            </div>
            <div class="navbar-end gap-2">
                <!-- Theme -->
                <div class="dropdown dropdown-end">
                    <div tabindex="0" role="button" class="btn btn-ghost btn-sm rounded-xl gap-2">
                        🎨 <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </div>
                    <ul tabindex="0" class="dropdown-content menu p-3 shadow-2xl bg-base-100/90 backdrop-blur-xl rounded-2xl w-48 mt-3 border border-base-200 z-[100]">
                        <li><button onclick="setTheme('winter')" class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200"><span class="w-3 h-3 rounded-full bg-sky-400"></span>Winter</button></li>
                        <li><button onclick="setTheme('light')"  class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200"><span class="w-3 h-3 rounded-full bg-yellow-300"></span>Light</button></li>
                        <li><button onclick="setTheme('night')"  class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200"><span class="w-3 h-3 rounded-full bg-indigo-500"></span>Night</button></li>
                        <li><button onclick="setTheme('dracula')" class="flex items-center gap-3 p-2 rounded-xl hover:bg-base-200"><span class="w-3 h-3 rounded-full bg-purple-500"></span>Dracula</button></li>
                    </ul>
                </div>
                <!-- Avatar -->
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-base-200">
                    <div class="w-7 h-7 rounded-full bg-primary text-primary-content flex items-center justify-center font-bold text-sm">@firstLetter</div>
                    <span class="text-sm font-semibold hidden sm:inline">@(User.Identity?.Name?.Split(" ")[0])</span>
                    <span class="badge badge-xs badge-warning font-bold">Admin</span>
                </div>
            </div>
        </div>
    </header>

    <!-- ── CONTENT ── -->
    <div class="main-wrapper">
        <div class="content-card shadow-xl">
            @RenderBody()
        </div>
    </div>

    <script>
        function setTheme(t) {
            document.documentElement.setAttribute("data-theme", t);
            localStorage.setItem("theme", t);
        }
        document.addEventListener("DOMContentLoaded", () => {
            const saved = localStorage.getItem("theme");
            if (saved) document.documentElement.setAttribute("data-theme", saved);

            const navbar = document.getElementById("mainNavbar");
            const progress = document.getElementById("scroll-progress");
            let lastY = window.scrollY;
            window.addEventListener("scroll", () => {
                const y = window.scrollY;
                const h = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                progress.style.width = (h > 0 ? (y / h) * 100 : 0) + "%";
                if (y > 10) navbar.classList.add("shadow-lg"); else navbar.classList.remove("shadow-lg");
                if (y > lastY && y > 90) { navbar.classList.remove("translate-y-0"); navbar.classList.add("-translate-y-full"); }
                else { navbar.classList.remove("-translate-y-full"); navbar.classList.add("translate-y-0"); }
                lastY = y;
            });

            const sidebar  = document.getElementById("sidebarFull");
            const overlay  = document.getElementById("sidebarOverlay");
            const openBtn  = document.getElementById("sidebarMobileToggle");
            const open  = () => { sidebar.classList.add("open"); overlay.classList.add("open"); document.body.style.overflow = "hidden"; };
            const close = () => { sidebar.classList.remove("open"); overlay.classList.remove("open"); document.body.style.overflow = ""; };
            if (openBtn) openBtn.addEventListener("click", open);
            if (overlay) overlay.addEventListener("click", close);
            document.addEventListener("keydown", e => { if (e.key === "Escape" && sidebar.classList.contains("open")) close(); });
            window.addEventListener("resize", () => { if (window.innerWidth >= 1024) close(); });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_NotificationPartial")
</body>
</html>
