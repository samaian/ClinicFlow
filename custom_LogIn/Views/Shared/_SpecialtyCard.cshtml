
@* @model SpecialtyDto *@

<a asp-controller="DoctorsUI" asp-action="Index" asp-route-specialty="@Model.Name"
       class="group card bg-base-100 border border-base-200 hover:border-primary/50 hover:shadow-xl transition-all duration-300 rounded-[2rem] overflow-hidden">
    <div class="card-body items-center text-center p-8">
        <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-4 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">@Model.Name</h3>
        <p class="text-sm opacity-60">Click to view all specialists in @Model.Name</p>
        <div class="mt-4 text-xs font-black uppercase tracking-widest text-primary opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all">
            Explore Now →
        </div>
    </div>
</a>

