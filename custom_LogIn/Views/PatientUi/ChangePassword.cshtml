@model ChangePasswordDto

@{
    Layout = "_PatientLayout";
    ViewData["Title"] = "Change Password";
}


<div class="min-h-screen flex items-center justify-center">

    <div class="card bg-base-100 shadow-xl border w-full max-w-lg">

        <div class="card-body">

            <div class="text-center mb-5">

                <div class="text-5xl mb-3">
                    🔒
                </div>

                <h2 class="text-3xl font-bold">
                    Change Password
                </h2>

                <p class="text-base-content/60 mt-2">
                    Update your password to keep your account secure.
                </p>

            </div>


            <form asp-action="ChangePassword"
                  method="post">


                @Html.AntiForgeryToken()


                <div asp-validation-summary="All"
                     class="alert alert-error mb-5">
                </div>



                <!-- Current Password -->
                <div class="form-control mb-4">

                    <label class="label">

                        <span class="label-text font-semibold">
                            Current Password
                        </span>

                    </label>


                    <input asp-for="CurrentPassword"
                           type="password"
                           placeholder="Enter current password"
                           class="input input-bordered w-full" />


                    <span asp-validation-for="CurrentPassword"
                          class="text-error text-sm mt-1">
                    </span>

                </div>




                <!-- New Password -->
                <div class="form-control mb-4">

                    <label class="label">

                        <span class="label-text font-semibold">
                            New Password
                        </span>

                    </label>


                    <input asp-for="NewPassword"
                           type="password"
                           placeholder="Enter new password"
                           class="input input-bordered w-full" />


                    <span asp-validation-for="NewPassword"
                          class="text-error text-sm mt-1">
                    </span>

                </div>





                <!-- Confirm Password -->
                <div class="form-control mb-6">

                    <label class="label">

                        <span class="label-text font-semibold">
                            Confirm Password
                        </span>

                    </label>


                    <input asp-for="ConfirmPassword"
                           type="password"
                           placeholder="Confirm new password"
                           class="input input-bordered w-full" />


                    <span asp-validation-for="ConfirmPassword"
                          class="text-error text-sm mt-1">
                    </span>

                </div>




                <button class="btn btn-warning w-full text-lg">

                    🔑 Change Password

                </button>


                <a asp-action="Profile"
                   class="btn btn-ghost w-full mt-3">

                    ← Back to Profile

                </a>


            </form>


        </div>

    </div>

</div>