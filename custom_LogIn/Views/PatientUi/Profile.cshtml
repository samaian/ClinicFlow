@model UpdateProfileViewModel
@{
    Layout = "_PatientLayout";
    ViewData["Title"] = "Profile";
    var firstName = User.Identity?.Name?.Split(' ')[0] ?? "Guest";
    var firstLetter = User.Identity?.Name?[0].ToString().ToUpper() ?? "P";
}

@section Styles {
    <style>
        .profile-card {
            background: rgba(255,255,255,.45);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 1.5rem;
            padding: 1.5rem;
        }

        [data-theme="night"] .profile-card,
        [data-theme="dracula"] .profile-card {
            background: rgba(17,24,39,.45);
            border-color: rgba(255,255,255,.08);
        }

        .profile-avatar {
            width: 100px;
            height: 100px;
            border-radius: 9999px;
            background: oklch(var(--p));
            color: oklch(var(--pc));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 2.5rem;
            margin: 0 auto;
            box-shadow: 0 8px 32px -8px oklch(var(--p)/.35);
            transition: transform .3s ease, box-shadow .3s ease;
        }

            .profile-avatar:hover {
                transform: scale(1.05);
            }

        .section-title {
            font-size: .95rem;
            font-weight: 700;
            padding-bottom: .65rem;
            border-bottom: 1px solid rgba(0,0,0,.06);
            margin-bottom: 1.1rem;
        }

        [data-theme="night"] .section-title,
        [data-theme="dracula"] .section-title {
            border-bottom-color: rgba(255,255,255,.06);
        }

        .ig {
            background: rgba(255,255,255,.3) !important;
            border-color: rgba(255,255,255,.15) !important;
            transition: all .2s;
        }

        [data-theme="night"] .ig, [data-theme="dracula"] .ig {
            background: rgba(17,24,39,.3) !important;
            border-color: rgba(255,255,255,.08) !important;
        }

        .ig:focus {
            border-color: oklch(var(--p)) !important;
            box-shadow: 0 0 0 2px oklch(var(--p)/.2) !important;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .55rem 1rem;
            border-radius: .75rem;
            font-size: .875rem;
            font-weight: 500;
            color: oklch(var(--bc)/.6);
            transition: all .2s ease;
            text-decoration: none;
        }

            .nav-link:hover {
                background: oklch(var(--p)/.08);
                color: oklch(var(--p));
            }

            .nav-link.active {
                background: oklch(var(--p));
                color: oklch(var(--pc));
                font-weight: 600;
                box-shadow: 0 4px 14px -4px oklch(var(--p)/.35);
            }
    </style>
}

<div class="space-y-5">

    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-xl font-black tracking-tight">
                👤 <span class="text-primary">@firstName</span>
            </h1>
            <p class="text-xs opacity-40 mt-0.5">Manage your personal information and account settings.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-xl text-sm border-0 shadow-sm">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error rounded-xl text-sm border-0">⚠️ @TempData["Error"]</div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-5">

        @* ── Left sidebar ── *@
        <div class="space-y-4">

            @* Avatar card *@
            <div class="profile-card text-center space-y-3">
                <div class="profile-avatar">@firstLetter</div>
                <div>
                    <div class="font-bold text-base">@Model.FullName</div>
                    <div class="text-xs opacity-40 mt-0.5">@Model.Email</div>
                    <span class="inline-block mt-2 badge badge-primary badge-sm font-semibold">Patient</span>
                </div>
                <div class="divider my-0"></div>
                <div class="space-y-1.5 text-left text-xs">
                    <div class="flex justify-between">
                        <span class="opacity-40">Date of Birth</span>
                        <span class="font-medium">@Model.DateOfBirth.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-40">Age</span>
                        <span class="font-medium">@(DateTime.Now.Year - Model.DateOfBirth.Year) yrs</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-40">Status</span>
                        <span class="badge badge-success badge-xs font-medium">✅ Verified</span>
                    </div>
                </div>
            </div>

            @* Nav links *@
            <div class="profile-card space-y-1 py-2">
                <a asp-action="Profile" class="nav-link active">✏️ Edit Profile</a>
                <a asp-action="ChangePassword" class="nav-link">🔒 Change Password</a>
                <a asp-action="ChangeEmail" class="nav-link">✉️ Change Email</a>
                <div class="divider my-1"></div>
                <a asp-action="Dashboard" class="nav-link">📅 My Appointments</a>
            </div>
        </div>

        @* ── Main form ── *@
        <div class="lg:col-span-3 profile-card">
            <h2 class="section-title">Personal Information</h2>

            <form asp-action="Profile" method="post" class="space-y-4">
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="form-control sm:col-span-2">
                        <label class="label font-semibold text-sm pb-1">Full Name</label>
                        <input asp-for="FullName" type="text"
                               class="input input-bordered rounded-xl ig w-full"
                               placeholder="Your full name" />
                        <span asp-validation-for="FullName" class="text-error text-xs mt-1"></span>
                    </div>

                    <div class="form-control">
                        <label class="label font-semibold text-sm pb-1">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date"
                               class="input input-bordered rounded-xl ig w-full" />
                        <span asp-validation-for="DateOfBirth" class="text-error text-xs mt-1"></span>
                    </div>

                    <div class="form-control">
                        <label class="label font-semibold text-sm pb-1">Email <span class="opacity-40 font-normal text-xs">(read-only)</span></label>
                        <input type="text" value="@Model.Email" readonly
                               class="input input-bordered rounded-xl w-full opacity-50 cursor-default" />
                    </div>
                </div>

                <div class="form-control">
                    <label class="label font-semibold text-sm pb-1">
                        Medical History
                        <span class="opacity-40 font-normal text-xs ml-1">optional</span>
                    </label>
                    <textarea asp-for="MedicalHistory" rows="4"
                              class="textarea textarea-bordered rounded-xl ig w-full"
                              placeholder="Allergies, chronic conditions, current medications…"></textarea>
                    <span asp-validation-for="MedicalHistory" class="text-error text-xs mt-1"></span>
                    <span class="text-xs opacity-40 mt-1">Helps your doctor personalise your care.</span>
                </div>

                <div class="flex gap-3 pt-1">
                    <button type="submit"
                            class="btn btn-primary btn-sm rounded-full px-6 shadow shadow-primary/20">
                        💾 Save Changes
                    </button>
                    <a asp-action="Dashboard" class="btn btn-ghost btn-sm rounded-full px-6">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}