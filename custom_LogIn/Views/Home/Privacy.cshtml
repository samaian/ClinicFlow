@{
    Layout = "_Layout";
    ViewData["Title"] = "Privacy Policy";
}

@section Styles {
    <style>
        /* إلغاء padding الـ main */
        main.container {
            max-width: 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }

        /* إلغاء margin-top الزائد من الفوتر */
        footer {
            margin-top: 0 !important;
        }

        /* منع التمرير الأفقي */
        body {
            overflow-x: hidden;
        }

        .container {
            max-width: 100% !important;
        }

        /* تنسيق النصوص القانونية */
        .legal-content h3 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
            color: var(--fallback-p, oklch(var(--p)));
        }

            .legal-content h3:first-of-type {
                margin-top: 0;
            }

        .legal-content p {
            opacity: 0.7;
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        .legal-content ul {
            opacity: 0.7;
            list-style-type: disc;
            padding-left: 1.5rem;
            margin-bottom: 1rem;
        }

            .legal-content ul li {
                margin-bottom: 0.5rem;
            }

        .legal-content .highlight-box {
            background: var(--fallback-p, oklch(var(--p)/0.05));
            border-left: 4px solid var(--fallback-p, oklch(var(--p)));
            padding: 1.5rem;
            border-radius: 1rem;
            margin: 1.5rem 0;
        }
    </style>
}

<div class="w-full">

    <!-- ==================== HERO SECTION ==================== -->
    <section class="pt-28 md:pt-32 pb-12 md:pb-16 bg-base-200/30 w-full">
        <div class="max-w-4xl mx-auto px-4 md:px-8 text-center reveal">
            <span class="inline-block text-primary font-bold text-sm tracking-widest uppercase bg-primary/10 px-4 py-1 rounded-full mb-4">Your Privacy Matters</span>
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter mb-4">
                Privacy <br class="hidden sm:block" />
                <span class="text-primary">Policy</span>
            </h1>
            <p class="text-lg md:text-xl opacity-60 max-w-2xl mx-auto">
                How we collect, use, and protect your personal and medical data.
            </p>
            <div class="flex justify-center mt-6">
                <span class="text-sm font-mono bg-base-100 px-6 py-2 rounded-full border border-base-200 shadow-sm opacity-60">
                    Last Updated: May 2026
                </span>
            </div>
        </div>
    </section>

    <!-- ==================== CONTENT ==================== -->
    <section class="py-16 md:py-24 w-full">
        <div class="max-w-4xl mx-auto px-4 md:px-8">
            <div class="card bg-base-100 p-8 md:p-12 lg:p-16 rounded-3xl shadow-xl border border-base-200 reveal">
                
                <div class="legal-content prose max-w-none prose-headings:font-bold prose-headings:text-primary prose-p:opacity-70 prose-li:opacity-70 prose-strong:text-primary prose-a:text-primary">
                    <p class="text-lg font-medium opacity-80">
                        Welcome to ClinicFlow. Your privacy is paramount to us. This policy describes how we collect, use, and protect your personal and medical data.
                    </p>

                    <!-- صندوق مميز للتأكيد -->
                    <div class="highlight-box">
                        <p class="font-semibold opacity-90 mb-0">
                            🔒 <strong>Our Commitment:</strong> We never sell your personal or medical data to third parties. Your trust is our foundation.
                        </p>
                    </div>
                    
                    <h3>1. Data Collection</h3>
                    <p>
                        We collect information you provide directly to us when:
                    </p>
                    <ul>
                        <li>Creating an account (name, email, phone number, date of birth).</li>
                        <li>Booking an appointment (medical history, symptoms, preferences).</li>
                        <li>Contacting our support team (communication records).</li>
                        <li>Subscribing to newsletters or updates (with your consent).</li>
                    </ul>

                    <h3>2. How We Use Data</h3>
                    <p>
                        We use your data to:
                    </p>
                    <ul>
                        <li>Facilitate clinical bookings and appointment management.</li>
                        <li>Process secure payments via our PCI-compliant payment gateway (Stripe).</li>
                        <li>Improve our services through analytics and user feedback.</li>
                        <li>Send you relevant notifications (appointment reminders, updates).</li>
                    </ul>
                    <p>
                        We never sell your personal or medical data to third parties for marketing purposes.
                    </p>

                    <h3>3. Security Standards</h3>
                    <p>
                        We employ bank-grade encryption (AES-256) for all sensitive data in transit and at rest. Our infrastructure is designed to comply with global healthcare privacy standards, including:
                    </p>
                    <ul>
                        <li><strong>GDPR</strong> (General Data Protection Regulation - EU).</li>
                        <li><strong>HIPAA</strong> guidelines for medical data protection (US).</li>
                        <li><strong>ISO 27001</strong> certified data centers.</li>
                    </ul>
                    <p>
                        Regular security audits and penetration testing are conducted to ensure your data remains safe.
                    </p>

                    <h3>4. Your Rights</h3>
                    <p>
                        As a user, you have the following rights regarding your personal data:
                    </p>
                    <ul>
                        <li><strong>Access:</strong> Request a copy of the data we hold about you.</li>
                        <li><strong>Correction:</strong> Update inaccurate or incomplete information.</li>
                        <li><strong>Deletion:</strong> Request permanent deletion of your account and associated data.</li>
                        <li><strong>Data Portability:</strong> Receive your data in a structured, machine-readable format.</li>
                        <li><strong>Withdraw Consent:</strong> Opt-out of non-essential data processing at any time.</li>
                    </ul>
                    <p>
                        To exercise any of these rights, visit your account dashboard or contact our data protection officer at <a href="mailto:privacy@clinicflow.com" class="text-primary font-semibold">privacy@clinicflow.com</a>.
                    </p>

                    <h3>5. Cookies</h3>
                    <p>
                        We use essential cookies to:
                    </p>
                    <ul>
                        <li>Maintain your session and authentication status.</li>
                        <li>Remember your preferences (theme settings, language).</li>
                        <li>Enable core platform functionality.</li>
                    </ul>
                    <p>
                        No non-essential tracking cookies (e.g., targeted advertising) are used without your explicit consent. You can manage cookie preferences in your browser settings.
                    </p>

                    <h3>6. Data Retention</h3>
                    <p>
                        We retain your data for as long as your account is active and for a reasonable period afterward to comply with legal obligations (e.g., medical records retention laws). You may request data deletion at any time.
                    </p>

                    <h3>7. Third-Party Services</h3>
                    <p>
                        We use trusted third-party providers for essential services, including:
                    </p>
                    <ul>
                        <li><strong>Stripe:</strong> Secure payment processing.</li>
                        <li><strong>Twilio:</strong> SMS and communication notifications.</li>
                        <li><strong>SendGrid:</strong> Email communications.</li>
                    </ul>
                    <p>
                        All third-party providers are contractually bound to protect your data and comply with privacy regulations.
                    </p>

                    <h3>8. Changes to This Policy</h3>
                    <p>
                        We may update this privacy policy periodically. Significant changes will be communicated via email or platform notifications. Continued use of the platform constitutes acceptance of the updated policy.
                    </p>
                </div>

                <!-- خط فاصل وتذييل -->
                <div class="pt-10 mt-10 border-t border-base-200 text-center">
                    <p class="text-sm opacity-40 italic">
                        For further inquiries, please reach out to <a href="mailto:privacy@clinicflow.com" class="text-primary font-semibold hover:underline">privacy@clinicflow.com</a>
                    </p>
                    <div class="flex flex-wrap justify-center gap-4 mt-6">
                        <a asp-controller="Home" asp-action="Terms" class="btn btn-ghost btn-sm rounded-full px-6">
                            Terms of Service
                        </a>
                        <a asp-controller="Home" asp-action="Contact" class="btn btn-primary btn-sm rounded-full px-6 shadow-md shadow-primary/20">
                            Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== CTA (Trust Badge) ==================== -->
    <section class="py-16 md:py-20 w-full bg-gradient-to-r from-primary/5 to-secondary/5">
        <div class="max-w-4xl mx-auto px-4 md:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center reveal">
                <div class="space-y-2">
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary mx-auto">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                    </div>
                    <h4 class="font-bold">ISO 27001 Certified</h4>
                    <p class="text-sm opacity-60">Information security management</p>
                </div>
                <div class="space-y-2">
                    <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary mx-auto">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                    </div>
                    <h4 class="font-bold">Bank-Grade Encryption</h4>
                    <p class="text-sm opacity-60">AES-256 for all data</p>
                </div>
                <div class="space-y-2">
                    <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center text-accent mx-auto">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    </div>
                    <h4 class="font-bold">GDPR & HIPAA Compliant</h4>
                    <p class="text-sm opacity-60">Global privacy standards</p>
                </div>
            </div>
        </div>
    </section>

</div>