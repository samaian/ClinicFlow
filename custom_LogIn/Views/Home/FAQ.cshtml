@{
    Layout = "_Layout";
    ViewData["Title"] = "Frequently Asked Questions";
}

@section Styles {
    <style>
        /* 1. إلغاء padding الـ main عشان الأقسام تاخد عرض كامل */
        main.container {
            max-width: 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }

        /* 2. إلغاء المسافة الزائدة فوق الفوتر */
        footer {
            margin-top: 0 !important;
        }

        /* 3. منع التمرير الأفقي */
        body {
            overflow-x: hidden;
        }

        .container {
            max-width: 100% !important;
        }

        /* 4. تأثيرات إضافية للـ Accordion */
        .faq-collapse {
            transition: all 0.3s ease;
        }

            .faq-collapse:hover {
                border-color: var(--fallback-p, oklch(var(--p)/0.3));
                transform: translateY(-2px);
                box-shadow: 0 8px 30px -8px rgba(0,0,0,0.08);
            }

            .faq-collapse .collapse-title {
                font-weight: 600;
                font-size: 1.1rem;
            }
            /* تغيير لون السهم عند الفتح */
            .faq-collapse input:checked ~ .collapse-title {
                color: var(--fallback-p, oklch(var(--p)));
            }
    </style>
}

<div class="w-full">

    <!-- ==================== HERO SECTION ==================== -->
    <section class="pt-28 md:pt-32 pb-12 md:pb-16 bg-base-200/30 w-full">
        <div class="max-w-4xl mx-auto px-4 md:px-8 text-center reveal">
            <span class="inline-block text-primary font-bold text-sm tracking-widest uppercase bg-primary/10 px-4 py-1 rounded-full mb-4">Knowledge Base</span>
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter mb-4">
                Frequently Asked <br class="hidden sm:block" />
                <span class="text-primary">Questions</span>
            </h1>
            <p class="text-lg md:text-xl opacity-60 max-w-2xl mx-auto">
                Everything you need to know about booking, payments, and managing your health journey with ClinicFlow.
            </p>

            <!-- شريط بحث وهمي (UI فقط) -->
            <div class="max-w-xl mx-auto mt-8 flex gap-3 bg-base-100 p-2 rounded-2xl shadow-md border border-base-200">
                <input type="text" placeholder="Search for answers..." class="input input-ghost flex-1 border-none bg-transparent focus:outline-none placeholder:opacity-40" />
                <button class="btn btn-primary rounded-xl px-6 shadow-lg shadow-primary/20">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    Search
                </button>
            </div>
        </div>
    </section>

    <!-- ==================== FAQ ACCORDION ==================== -->
    <section class="py-16 md:py-24 w-full">
        <div class="max-w-4xl mx-auto px-4 md:px-8 space-y-6">

            <!-- السؤال 1 -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" checked="checked" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    How do I book an appointment with a specialist?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>Booking an appointment is simple. Browse our <a asp-controller="DoctorsUI" asp-action="Index" class="text-primary font-semibold hover:underline">Doctors directory</a>, select your preferred specialist, choose an available time slot, and confirm your booking. You'll receive an instant confirmation email and reminder notifications.</p>
                </div>
            </div>

            <!-- السؤال 2 -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    Can I reschedule or cancel my booking?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>Yes, absolutely. You can reschedule or cancel your appointment up to 24 hours before the scheduled time without any penalty. Simply log in to your dashboard, navigate to "My Appointments," and select the booking you wish to modify. For cancellations within 24 hours, please contact our support team directly.</p>
                </div>
            </div>

            <!-- السؤال 3 -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    What payment methods are accepted?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>We accept all major credit and debit cards (Visa, Mastercard, American Express), as well as digital wallets like Apple Pay and Google Pay. All payments are processed through our secure, PCI-compliant payment gateway with bank-grade encryption.</p>
                </div>
            </div>

            <!-- السؤال 4 -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    How is my medical data protected?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>Your privacy is our top priority. ClinicFlow is fully compliant with international data protection regulations (GDPR, HIPAA). We use end-to-end encryption for all data transmissions, and your medical records are stored securely in ISO 27001 certified data centers. We never share your personal information with third parties without your explicit consent.</p>
                </div>
            </div>

            <!-- السؤال 5 -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    How do I find the right specialist for my condition?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>Our platform features a comprehensive filtering system. You can search by specialty, location, availability, and patient ratings. Each doctor's profile includes their qualifications, years of experience, and areas of expertise. We also provide a symptom-based recommendation tool to guide you toward the most suitable specialist.</p>
                </div>
            </div>

            <!-- السؤال 6 -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    What is your refund policy?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>If you cancel within the permitted timeframe (24+ hours before the appointment), a full refund will be processed to your original payment method within 3-5 business days. For missed appointments or late cancellations, we may offer a partial refund or credit toward a future booking at our discretion. Please refer to our <a asp-action="Terms" class="text-primary font-semibold hover:underline">Terms of Service</a> for full details.</p>
                </div>
            </div>

            <!-- السؤال 7 (إضافي) -->
            <div class="collapse collapse-arrow faq-collapse bg-base-100 border border-base-200 rounded-2xl shadow-sm">
                <input type="radio" name="faq-accordion" />
                <div class="collapse-title text-lg md:text-xl font-bold">
                    Do you offer telemedicine / virtual consultations?
                </div>
                <div class="collapse-content text-base opacity-70 leading-relaxed">
                    <p>Yes! Many of our specialists offer secure video consultations. You can choose between in-person and virtual appointments during the booking process. For virtual visits, you'll receive a secure video link via email and SMS prior to your appointment. All video sessions are encrypted and comply with medical privacy standards.</p>
                </div>
            </div>

        </div>
    </section>

    <!-- ==================== CTA SECTION (Still have questions?) ==================== -->
    <section class="py-20 md:py-28 w-full bg-gradient-to-r from-primary/5 via-primary/10 to-primary/5">
        <div class="max-w-4xl mx-auto px-4 md:px-8 text-center space-y-8 reveal">
            <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mx-auto">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            </div>
            <h2 class="text-4xl md:text-5xl font-black tracking-tight">
                Still have <span class="text-primary">questions</span>?
            </h2>
            <p class="text-lg md:text-xl opacity-70 max-w-2xl mx-auto">
                Our dedicated support team is here to help. Reach out to us and we'll get back to you within 24 hours.
            </p>
            <div class="flex flex-wrap justify-center gap-4 pt-4">
                <a asp-controller="Home" asp-action="Contact" class="btn btn-primary btn-lg rounded-2xl px-12 shadow-xl shadow-primary/20 hover:shadow-primary/40 transition-all">
                    Contact Support
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline btn-lg rounded-2xl px-12">
                    Return Home
                </a>
            </div>
        </div>
    </section>

</div>