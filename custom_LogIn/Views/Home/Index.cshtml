                            <input type="radio" class="mask mask-star-2 mask-half-2 bg-orange-400" checked disabled />
                            <input type="radio" class="mask mask-star-2 mask-half-1 bg-orange-400" checked disabled />
                            <input type="radio" class="mask mask-star-2 mask-half-2 bg-orange-400" checked disabled />
