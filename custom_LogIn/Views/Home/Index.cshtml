            <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-4">Discover the Right Specialist</h2>
            <p class="text-base md:text-lg text-base-content/60 max-w-2xl mx-auto">
                Search by name, specialty, or budget to find your perfect match.
            </p>
        </div>

        <form asp-controller="DoctorsUI" asp-action="Index" method="get" 
              class="search-glass p-3 md:p-4 rounded-3xl shadow-xl flex flex-col md:flex-row gap-3 md:gap-4 border border-base-200/50">
            
            <!-- حقل البحث بالاسم -->
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none opacity-40">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input name="name" type="text" placeholder="Search doctor by name..." 
                       class="input input-lg w-full pl-12 rounded-2xl bg-base-100/50 border-0 focus:ring-2 focus:ring-primary/30 text-base placeholder:opacity-50" />
            </div>

            <!-- فاصل عمودي -->
            <div class="hidden md:block w-px h-10 bg-base-300/50 self-center"></div>

            <!-- حقل التخصص -->
            <div class="flex-1">
                <select name="specialty" class="select select-lg w-full rounded-2xl bg-base-100/50 border-0 focus:ring-2 focus:ring-primary/30 text-base">
                    <option value="">All Specialties</option>
                    @foreach(var s in specialties) {
                        <option value="@s.Name">@s.Name</option>
                    }
                </select>
            </div>

            <!-- زر البحث -->
            <button type="submit" class="btn btn-primary btn-lg rounded-2xl px-8 md:px-12 h-14 shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                Search
            </button>
        </form>

        <!-- إحصائيات سريعة تحت البحث -->
        <div class="flex flex-wrap justify-center gap-6 md:gap-10 mt-8 text-sm opacity-60">
            <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                500+ Verified Specialists
            </span>
            <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-secondary"></span>
                30+ Medical Specialties
            </span>
            <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-accent"></span>
                98% Patient Satisfaction
            </span>
        </div>
    </div>
</section>



