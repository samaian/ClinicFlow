@{
    Layout = "_Layout";
    ViewData["Title"] = "Payment Successful";
}

@section Styles {
    <style>
        .success-card {
            background: rgba(255,255,255,0.55);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.2);
        }
        [data-theme="night"] .success-card,
        [data-theme="dracula"] .success-card {
            background: rgba(17,24,39,0.55);
            border: 1px solid rgba(255,255,255,0.08);
        }
        .success-icon {
            animation: pulse 2s ease-in-out infinite;
        }
        @@keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        .checkmark-circle {
            stroke-dasharray: 166;
            stroke-dashoffset: 166;
            animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
        }
        .checkmark-check {
            stroke-dasharray: 48;
            stroke-dashoffset: 48;
            animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.6s forwards;
        }
        @@keyframes stroke {
            to { stroke-dashoffset: 0; }
        }
    </style>
}

<div class="w-full min-h-screen flex items-center justify-center bg-base-200/30 py-32">
    <div class="max-w-lg w-full mx-auto px-4 md:px-8">
        
        <div class="success-card card shadow-2xl rounded-3xl p-10 md:p-14 border border-base-200 transition-all duration-300 text-center">
            
            <!-- أيقونة النجاح المتحركة -->
            <div class="flex justify-center mb-6">
                <div class="relative">
                    <div class="w-28 h-28 rounded-full bg-success/10 flex items-center justify-center success-icon">
                        <svg class="w-16 h-16 text-success" viewBox="0 0 52 52" fill="none" stroke="currentColor">
                            <circle cx="26" cy="26" r="25" fill="none" stroke="currentColor" stroke-width="2" class="checkmark-circle" />
                            <path fill="none" stroke="currentColor" stroke-width="4" d="M14.1 27.2l7.1 7.2 16.7-16.8" class="checkmark-check" />
                        </svg>
                    </div>
                    <!-- نجوم ديكورية -->
                    <div class="absolute -top-2 -right-2 text-2xl opacity-20">✦</div>
                    <div class="absolute -bottom-2 -left-2 text-2xl opacity-20">✦</div>
                </div>
            </div>

            <!-- العنوان -->
            <h1 class="text-4xl md:text-5xl font-black tracking-tight text-success mb-3">
                Payment Successful!
            </h1>

            <!-- النصوص -->
            <p class="text-lg opacity-70 leading-relaxed max-w-sm mx-auto">
                Your payment has been completed successfully.
            </p>
            <p class="text-sm opacity-50 mt-2 font-medium">
                Thank you for your booking. You will receive a confirmation email shortly.
            </p>


            <!-- الأزرار -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
                <a asp-controller="Home" asp-action="Index" 
                   class="btn btn-primary btn-lg rounded-2xl px-12 shadow-xl shadow-primary/20 hover:shadow-primary/40 transition-all">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1"/></svg>
                    Back to Home
                </a>
                <a asp-controller="Appointments" asp-action="Index" 
                   class="btn btn-outline btn-lg rounded-2xl px-12">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    My Appointments
                </a>
            </div>

            <!-- شارة الأمان -->
            <div class="mt-8 flex items-center justify-center gap-4 text-xs opacity-40 font-bold uppercase tracking-widest">
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    Secure Payment
                </span>
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.512 5.73 6.974 6 7.5 6A1.5 1.5 0 019 7.5V8a2 2 0 004 0 2 2 0 011.523-1.943A5.977 5.977 0 0116 10c0 .34-.028.675-.083 1H15a2 2 0 00-2 2v2.162A5.978 5.978 0 0110 16c-1.074 0-2.082-.282-2.958-.759A1.5 1.5 0 006.5 14h-1.04A5.977 5.977 0 014 10c0-1.016.283-1.97.332-1.973z" clip-rule="evenodd"/></svg>
                    Stripe Secured
                </span>
            </div>
        </div>
    </div>
</div>